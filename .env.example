# ── Database ──────────────────────────────────
POSTGRES_DB=open_brain
POSTGRES_USER=brain_user
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
MCP_PORT=8000

# ── LLM ───────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here

# ── Memory ────────────────────────────────────
MEMORY_RETENTION_MONTHS=12
