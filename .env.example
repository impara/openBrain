# ── Database ──────────────────────────────────
POSTGRES_DB=open_brain
POSTGRES_USER=brain_user
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
MCP_PORT=8001

# ── LLM / Structured Extraction ───────────────
# Supported providers in v1: openai, openrouter, ollama
OPENBRAIN_LLM_PROVIDER=openai
OPENBRAIN_LLM_MODEL=gpt-4o-mini
# OPENBRAIN_LLM_BASE_URL=
# OPENBRAIN_LLM_API_KEY=sk-your-key-here
#
# Optional OpenRouter headers when OPENBRAIN_LLM_PROVIDER=openrouter
# OPENBRAIN_OPENROUTER_SITE_URL=https://your-app.example
# OPENBRAIN_OPENROUTER_APP_NAME=OpenBrain

# ── Embeddings ─────────────────────────────────
# Supported providers in v1: openai, openrouter, ollama
OPENBRAIN_EMBEDDING_PROVIDER=openai
OPENBRAIN_EMBEDDING_MODEL=text-embedding-3-small
# OPENBRAIN_EMBEDDING_BASE_URL=
# OPENBRAIN_EMBEDDING_API_KEY=sk-your-key-here
OPENBRAIN_EMBEDDING_DIMS=1536

# ── Graph ──────────────────────────────────────
OPENBRAIN_GRAPH_NAME=brain_graph_v2

# ── MCP ───────────────────────────────────────
# streamable-http (default) or stdio for local IDE
# MCP_TRANSPORT=streamable-http

OPENBRAIN_CAPTURE_MODE=async
OPENBRAIN_INGEST_WORKERS=1
OPENBRAIN_INGEST_POLL_MS=250

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_AUTO_CAPTURE=false
